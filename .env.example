# Exemplo de configuração de variáveis de ambiente para o MoedaFlow.
# Copie este arquivo para .env na raiz do projeto e insira suas chaves reais.

# Chave da API GNews (gnews.io) - Recomendado
VITE_GNEWS_KEY=insira_seu_token_gnews_aqui

# Chave da NewsAPI (newsapi.org) - Alternativa
# VITE_NEWSAPI_KEY=insira_sua_apiKey_newsapi_aqui
